{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-repo-harness.local/schemas/handoff.schema.json",
  "title": "Agent-Repo-Harness handoff",
  "type": "object",
  "description": "Optional structured representation for handoff.md content.",
  "required": ["current_task", "current_state", "changed_files", "verification"],
  "properties": {
    "current_task": { "type": "string" },
    "current_state": { "type": "string" },
    "confirmed_facts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "result"],
        "properties": {
          "command": { "type": "string" },
          "result": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "open_issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_recommended_action": { "type": "string" }
  },
  "additionalProperties": true
}
